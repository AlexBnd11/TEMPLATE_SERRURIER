---
import { whyChooseUsItems as defaultItems } from '@config/why-choose-us';
import { siteConfig } from '@config/site';
import type { WhyChooseUsContent } from '@lib/cms/queries';

interface Props {
  content?: WhyChooseUsContent | null;
}

const { content } = Astro.props;

const cmsItems = content?.items && content.items.length > 0 ? content.items : null;
const title = content?.title || `Pourquoi choisir ${siteConfig.name} ?`;
const description =
  content?.description ||
  "Parce que lorsqu'on est bloqué devant sa porte, on n'a pas le droit à l'erreur. DSLR, c'est un artisan serrurier local qui mise sur l'honnêteté, la transparence et le travail bien fait.";

const itemsSource = cmsItems ?? defaultItems;
const certificationItem = itemsSource.find((i) => i.image && !i.icon);
const otherItems = itemsSource.filter((i) => !i.image || !!i.icon);

---

<section id="pourquoi-dslr" class="py-24 bg-white">
  <div class="container mx-auto px-4 lg:px-6">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <!-- Texte -->
      <div class="lg:col-span-5" data-animate>
        <span class="block w-10 h-[3px] bg-primary rounded-full mb-4" aria-hidden="true"></span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-semibold text-gray-900 mb-5 leading-tight">
          {title}
        </h2>
        <p class="text-lg text-gray-600">
          {description}
        </p>
      </div>

      <!-- Items -->
      <div class="lg:col-span-7 space-y-6">
        <!-- Cards standard -->
        <div class="grid sm:grid-cols-2 gap-6">
          {otherItems.map((item) => (
            <article
              class="bg-gray-50 border border-gray-200 rounded-xl p-6 hover:border-primary hover:shadow-sm transition-colors"
              data-animate
            >
              <div class="flex items-center justify-center w-12 h-12 rounded-full bg-primary/10 mb-4 overflow-hidden shrink-0">
                {item.icon
                  ? <img src={item.icon} alt="" class="w-6 h-6 object-contain" aria-hidden="true" style="max-width:1.5rem;max-height:1.5rem;" />
                  : null}
              </div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">
                {item.title}
              </h3>
              <p class="text-sm text-gray-600 leading-relaxed">
                {item.description}
              </p>
            </article>
          ))}
        </div>

        <!-- Card certification (image, pleine largeur) -->
        {certificationItem && certificationItem.image && (
          <article
            class="bg-gray-50 border border-gray-200 rounded-xl p-6 sm:p-8 hover:border-primary hover:shadow-sm transition-colors flex flex-col sm:flex-row gap-6 sm:gap-8 items-center"
            data-animate
          >
            <div class="shrink-0 w-full sm:w-40 sm:self-stretch flex items-center justify-center rounded-xl bg-white border border-gray-200 p-2 shadow-sm min-h-[100px] overflow-hidden">
              <img
                src={typeof certificationItem.image === 'string' ? certificationItem.image : certificationItem.image.url}
                alt="Certification RNCP"
                class="max-h-20 max-w-full w-auto object-contain object-center"
                width="120"
                height="80"
              />
            </div>
            <div class="min-w-0 flex-1">
              <h3 class="text-lg font-semibold text-gray-900 mb-2">
                {certificationItem.title}
              </h3>
              <p class="text-sm text-gray-600 leading-relaxed">
                {certificationItem.description}
              </p>
            </div>
          </article>
        )}
      </div>
    </div>
  </div>
</section>
