---
import { siteConfig } from '@config/site';
import type { HeroContent } from '@lib/cms/queries';

interface Props {
  content?: HeroContent | null;
}

const { content } = Astro.props;

const logoSrc = content?.logo?.url ?? '/logo_dslr_transparent.png';
const logoAlt = content?.logo?.alternativeText || siteConfig.name;

const backgroundSrc = content?.backgroundImage?.url ?? '/background_hero.webp';

const heroTagline =
  content?.subtitle || 'Serrurier d’urgence 7j/7 – La Rochelle & CDA';
---

<section id="hero" class="relative min-h-[100vh] flex items-center justify-center overflow-hidden bg-black">
  <div class="absolute inset-0">
    <img
      src={backgroundSrc}
      alt="Serrurier en intervention à La Rochelle"
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/70 to-black/85" />
  </div>

  <div class="relative z-10 container mx-auto px-4 lg:px-6 py-24 md:py-32">
    <div class="flex flex-col items-center text-center gap-12 md:gap-12">
      <img
        src={logoSrc}
        alt={logoAlt}
        class="h-72 sm:h-80 md:h-[26rem] lg:h-[28rem] xl:h-[30rem] w-auto max-w-[90vw] object-contain drop-shadow-[0_16px_40px_rgba(0,0,0,0.7)] filter brightness-95 saturate-75"
        loading="eager"
      />

      <p class="text-sm md:text-base uppercase tracking-[0.18em] text-primary/90 font-semibold">
        {heroTagline}
      </p>

      <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-3">
        <a
          href={`tel:${siteConfig.phone}`}
          class="inline-flex items-center justify-center gap-3 rounded-full bg-black/70 px-5 min-h-[3.25rem] text-xs md:text-sm text-gray-100 border border-white/15 shadow-[0_10px_25px_rgba(0,0,0,0.5)] hover:bg-black/80 hover:border-primary/60 hover:shadow-[0_14px_35px_rgba(0,0,0,0.65)] transition-all"
          aria-label={`Appeler en urgence ${siteConfig.name}`}
        >
          <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-black">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h2.28a1 1 0 01.95.684l1.22 3.663a1 1 0 01-.502 1.21l-1.52.76a11.042 11.042 0 005.516 5.516l.76-1.52a1 1 0 011.21-.502l3.663 1.22A1 1 0 0121 17.72V20a2 2 0 01-2 2h-1C9.716 22 3 15.284 3 7V5z"
              />
            </svg>
          </span>
          <div class="flex flex-col items-start leading-tight text-left">
            <span class="text-[0.7rem] uppercase tracking-[0.16em] text-gray-300">Urgence serrurier</span>
            <span class="text-[14px] text-white font-medium">{siteConfig.phoneFormatted}</span>
          </div>
        </a>

        <a
          href="#avis-clients"
          class="inline-flex items-center justify-center gap-3 rounded-full bg-black/70 px-5 min-h-[3.25rem] text-xs md:text-sm text-gray-100 border border-white/15 shadow-[0_10px_25px_rgba(0,0,0,0.5)] hover:bg-black/80 hover:border-primary/60 hover:shadow-[0_14px_35px_rgba(0,0,0,0.65)] transition-all"
          aria-label="Voir les avis Google de DSLR Serrurier La Rochelle"
        >
          <div class="flex items-center gap-1 text-yellow-300 shrink-0">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path
                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
              />
            </svg>
            <span class="font-semibold">{siteConfig.stats.averageRating.toFixed(1)}/5</span>
          </div>
          <span class="h-4 w-px bg-white/20 shrink-0" aria-hidden="true" />
          <div class="flex flex-col items-start leading-tight text-left min-w-0">
            <span class="text-[0.7rem] uppercase tracking-[0.16em] text-gray-300">Avis Google</span>
            <span class="text-[0.7rem] md:text-xs text-gray-200">
              Artisan serrurier local à {siteConfig.city}
            </span>
          </div>
        </a>
      </div>
    </div>
  </div>

  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 text-center text-gray-300">
    <a
      id="hero-link-services"
      href="#services"
      class="flex flex-col items-center text-xs uppercase tracking-wide hover:text-white transition-colors"
      aria-label="Découvrir les services de serrurerie"
    >
      <span>Voir les services</span>
      <svg class="w-6 h-6 mt-3 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </a>
  </div>
</section>

<script>
  document.getElementById('hero-link-services')?.addEventListener('click', (e) => {
    const target = document.getElementById('services');
    if (target) {
      e.preventDefault();
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });
</script>
