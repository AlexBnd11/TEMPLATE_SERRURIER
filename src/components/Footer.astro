---
import { siteConfig } from '@config/site';
import type { SiteSettings } from '@lib/cms/queries';

interface Props {
  siteSettings?: SiteSettings | null;
}

const { siteSettings } = Astro.props;

const footerText =
  siteSettings?.footerText ||
  `${siteConfig.tagline}. Ouverture de porte d'urgence, Dépannage serrurier 7j/7 de 7h à minuit sur La Rochelle et la CDA.`;
---

<footer class="bg-dark border-t border-dark-lighter text-gray-300">
  <div class="container mx-auto px-4 lg:px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- About -->
      <div>
        <h2 class="text-xl font-bold text-white mb-3">{siteConfig.name}</h2>
        <p class="text-sm text-gray-400 mb-4">
          {footerText}
        </p>
        <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-semibold">
          <span>Serrurier certifié RNCP</span>
        </div>
      </div>

      <!-- Liens rapides -->
      <div>
        <h3 class="text-lg font-semibold text-white mb-3">Navigation</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="/" class="hover:text-primary transition-colors">Accueil</a>
          </li>
          <li>
            <a href="/prix/" class="hover:text-primary transition-colors">Tarifs</a>
          </li>
          <li>
            <a href="/faq/" class="hover:text-primary transition-colors">FAQ / Conseils</a>
          </li>
          <li>
            <a href="/contact/" class="hover:text-primary transition-colors">Contact</a>
          </li>
        </ul>
      </div>

      <!-- Zones & services -->
      <div>
        <h3 class="text-lg font-semibold text-white mb-3">Zones d’intervention</h3>
        <p class="text-sm text-gray-400 mb-3">
          La Rochelle et alentours :
        </p>
        <p class="text-sm text-gray-400">
          Aytré, Puilboreau, Lagord, Périgny, Dompierre-sur-Mer, La Jarrie, La Jarne, Saint-Rogatien, Châtelaillon, Angoulins, Marsilly, Esnandes, Charron, St-Xandre, Puilboreau et proches alentours.
        </p>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-lg font-semibold text-white mb-3">Contact rapide</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start space-x-3">
            <svg class="w-5 h-5 mt-0.5 flex-shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              />
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
              />
            </svg>
            <span>{siteConfig.address.full}</span>
          </li>
          <li class="flex items-center space-x-3">
            <svg class="w-5 h-5 flex-shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h2.28a1 1 0 01.95.684l1.22 3.663a1 1 0 01-.502 1.21l-1.52.76a11.042 11.042 0 005.516 5.516l.76-1.52a1 1 0 011.21-.502l3.663 1.22A1 1 0 0121 17.72V20a2 2 0 01-2 2h-1C9.716 22 3 15.284 3 7V5z"
              />
            </svg>
            <a href={`tel:${siteConfig.phone}`} class="hover:text-primary transition-colors">
              {siteConfig.phoneFormatted}
            </a>
          </li>
          {siteConfig.email && (
            <li class="flex items-center space-x-3">
              <svg class="w-5 h-5 flex-shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                />
              </svg>
              <a href={`mailto:${siteConfig.email}`} class="hover:text-primary transition-colors">
                {siteConfig.email}
              </a>
            </li>
          )}
          <li class="flex items-center space-x-3">
            <svg class="w-5 h-5 flex-shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            <span>Urgence 7j/7 de 7h à minuit</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-dark-lighter text-xs text-gray-500 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
      <p>
        &copy; {new Date().getFullYear()} {siteConfig.name}. Tous droits réservés.
      </p>
      <p class="space-x-2">
        <a href="/mentions-legales/" class="hover:text-primary transition-colors">Mentions légales</a>
        <span>•</span>
        <a href="/politique-de-confidentialite/" class="hover:text-primary transition-colors">
          Politique de confidentialité
        </a>
        <span>•</span>
        <a href="/parametres-des-cookies/" class="hover:text-primary transition-colors">
          Paramètres des cookies
        </a>
      </p>
    </div>
  </div>
</footer>

