---
import { services as staticServices } from '@config/services';
import type { ServiceItem } from '@lib/cms/queries';

interface Props {
  content?: ServiceItem[] | null;
}

const { content } = Astro.props;

const staticServiceImages: Record<string, string> = {
  'ouverture-porte': '/ouverture_porte.webp',
  'serrure-bloquee-perdue-cassee': '/serrure_bloquee.webp',
  'remplacement-pose-serrure': '/pose_serrure.webp',
  'renforcement-anti-effraction': '/serrure_robuste.webp',
};

// Si on a des services CMS, on les utilise, sinon fallback statique
const hasCms = content && content.length > 0;
---

<section id="services" class="scroll-mt-24 py-24 bg-gray-50">
  <div class="container mx-auto px-4 lg:px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14" data-animate>
        <span class="block w-10 h-[3px] bg-primary rounded-full mb-4 mx-auto" aria-hidden="true"></span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-semibold text-gray-900 mb-4">
          Services de serrurerie à La Rochelle
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Toutes les interventions essentielles : ouverture de porte, dépannage, remplacement de serrure et renforcement
          anti-effraction, avec tarifs clairs et devis gratuits.
        </p>
      </div>

      <div class="space-y-10">
        {hasCms
          ? content.slice(0, 4).map((service, index) => (
              <article
                class={`flex flex-col ${index % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-8 lg:gap-12 items-center`}
                data-animate
              >
                <!-- Illustration -->
                <div class="w-full lg:w-1/2">
                  <div class="relative aspect-[16/10] rounded-2xl overflow-hidden bg-gradient-to-br from-dark to-dark-light">
                    {service.image ? (
                      <img
                        src={service.image.url}
                        alt={service.image.alternativeText || `${service.title} - serrurier La Rochelle`}
                        class="w-full h-full object-cover"
                        loading="lazy"
                      />
                    ) : (
                      <div class="absolute inset-0 flex flex-col items-center justify-center text-center text-gray-100 px-6">
                        {service.iconUrl && (
                          <img src={service.iconUrl} alt="" class="w-12 h-12 mb-3 object-contain" aria-hidden="true" />
                        )}
                        <p class="font-semibold text-base">{service.title}</p>
                      </div>
                    )}
                  </div>
                </div>

                <!-- Contenu -->
                <div class="w-full lg:w-1/2">
                  <div class="flex items-center space-x-3 mb-3">
                    {service.iconUrl && (
                      <div class="w-11 h-11 rounded-xl bg-primary/10 flex items-center justify-center shrink-0">
                        <img src={service.iconUrl} alt="" class="w-6 h-6 object-contain" aria-hidden="true" />
                      </div>
                    )}
                    <h3 class="text-2xl md:text-3xl font-display font-semibold text-gray-900">
                      {service.title}
                    </h3>
                  </div>
                  <p class="text-gray-700 mb-4">
                    {service.shortDescription}
                  </p>
                  {service.price && (
                    <p class="text-sm font-semibold text-dark mb-4">
                      {service.price}
                    </p>
                  )}
                  <a
                    href="/prix/"
                    class="inline-flex items-center text-sm font-semibold text-primary hover:text-primary-dark group"
                  >
                    <span>Voir détails & tarifs</span>
                    <svg class="w-4 h-4 ml-1 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </article>
            ))
          : staticServices.slice(0, 4).map((service, index) => (
              <article
                class={`flex flex-col ${index % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-8 lg:gap-12 items-center`}
                data-animate
              >
                <div class="w-full lg:w-1/2">
                  <div class="relative aspect-[16/10] rounded-2xl overflow-hidden bg-gradient-to-br from-dark to-dark-light">
                    <img
                      src={staticServiceImages[service.id] ?? `/images/services/${service.id}.jpg`}
                      alt={`${service.name} - serrurier La Rochelle`}
                      class="w-full h-full object-cover"
                      loading="lazy"
                      onerror="this.style.display='none'"
                    />
                  </div>
                </div>
                <div class="w-full lg:w-1/2">
                  <h3 class="text-2xl md:text-3xl font-display font-semibold text-gray-900 mb-3">
                    {service.name}
                  </h3>
                  <p class="text-gray-700 mb-4">{service.shortDescription}</p>
                  {service.price && (
                    <p class="text-sm font-semibold text-dark mb-4">{service.price}</p>
                  )}
                  <a
                    href={`/prix/#${service.id}`}
                    class="inline-flex items-center text-sm font-semibold text-primary hover:text-primary-dark group"
                  >
                    <span>Voir détails & tarifs</span>
                    <svg class="w-4 h-4 ml-1 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </article>
            ))
        }
      </div>
    </div>
  </div>
</section>
