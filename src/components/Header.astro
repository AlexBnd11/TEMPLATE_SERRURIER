---
import { siteConfig } from '@config/site';

const currentPath = Astro.url.pathname;
const isHomePage = currentPath === '/' || currentPath === '/index.html';
---

<header
  id="main-header"
  class={`group fixed top-0 left-0 right-0 z-50 transition-all duration-300 ${
    isHomePage ? 'bg-transparent backdrop-blur-none' : 'bg-white/95 backdrop-blur-sm border-b border-gray-200 shadow-sm always-show'
  }`}
>
  <nav class="container mx-auto px-3 lg:px-4 py-3" aria-label="Navigation principale">
    <div class="flex items-center justify-between gap-4">
      <!-- Logo (masqué sur la hero, affiché après scroll sur la home) -->
      <a
        id="brand-block"
        href="/"
        class={`flex items-center space-x-3 group/logo ${
          isHomePage ? 'opacity-0 pointer-events-none' : 'opacity-100'
        } transition-opacity duration-300`}
        aria-label={`${siteConfig.name} - Retour à l'accueil`}
      >
        <img
          src="/logo_dslr_bleu.jpg"
          alt="Logo DSLR Serrurier La Rochelle"
          class="h-[4rem] w-auto mb-2 object-contain md:h-[4rem] filter brightness-95 saturate-75 rounded-lg"
          loading="lazy"
        />
        <div class="flex flex-col">
          <span
            class={`text-sm font-semibold tracking-wide uppercase transition-colors ${
              isHomePage ? 'text-white group-hover/logo:text-primary' : 'text-dark group-hover/logo:text-primary'
            } group-[.scrolled]:text-dark group-[.scrolled]:group-hover/logo:text-primary`}
          >
            DSLR Serrurier
          </span>
          <span
            class={`text-xs transition-colors ${
              isHomePage ? 'text-gray-200' : 'text-gray-500'
            } group-[.scrolled]:text-gray-500`}
          >
            La Rochelle & CDA
          </span>
        </div>
      </a>

      <!-- Desktop navigation -->
      <ul class="hidden md:flex items-center space-x-1" role="menubar">
        <li role="none">
          <a
            href="/"
            class={`nav-link px-4 py-2.5 text-sm font-medium rounded-full transition-all ${
              currentPath === '/'
                ? isHomePage
                  ? 'text-white bg-white/10 backdrop-blur-sm group-[.scrolled]:text-primary group-[.scrolled]:bg-primary/10'
                  : 'text-primary bg-primary/10'
                : isHomePage
                  ? 'text-white/90 hover:text-white hover:bg-white/10 group-[.scrolled]:text-gray-700 group-[.scrolled]:hover:text-primary group-[.scrolled]:hover:bg-gray-50'
                  : 'text-gray-700 hover:text-primary hover:bg-gray-50'
            }`}
            role="menuitem"
            aria-current={currentPath === '/' ? 'page' : undefined}
          >
            Accueil
          </a>
        </li>
        <li role="none">
          <a
            href="/prix/"
            class={`nav-link px-4 py-2.5 text-sm font-medium rounded-full transition-all ${
              currentPath.startsWith('/prix')
                ? isHomePage
                  ? 'text-white bg-white/10 backdrop-blur-sm group-[.scrolled]:text-primary group-[.scrolled]:bg-primary/10'
                  : 'text-primary bg-primary/10'
                : isHomePage
                  ? 'text-white/90 hover:text-white hover:bg-white/10 group-[.scrolled]:text-gray-700 group-[.scrolled]:hover:text-primary group-[.scrolled]:hover:bg-gray-50'
                  : 'text-gray-700 hover:text-primary hover:bg-gray-50'
            }`}
            role="menuitem"
            aria-current={currentPath.startsWith('/prix') ? 'page' : undefined}
          >
            Tarifs
          </a>
        </li>
        <li role="none">
          <a
            href="/faq/"
            class={`nav-link px-4 py-2.5 text-sm font-medium rounded-full transition-all ${
              currentPath.startsWith('/faq')
                ? isHomePage
                  ? 'text-white bg-white/10 backdrop-blur-sm group-[.scrolled]:text-primary group-[.scrolled]:bg-primary/10'
                  : 'text-primary bg-primary/10'
                : isHomePage
                  ? 'text-white/90 hover:text-white hover:bg-white/10 group-[.scrolled]:text-gray-700 group-[.scrolled]:hover:text-primary group-[.scrolled]:hover:bg-gray-50'
                  : 'text-gray-700 hover:text-primary hover:bg-gray-50'
            }`}
            role="menuitem"
            aria-current={currentPath.startsWith('/faq') ? 'page' : undefined}
          >
            FAQ / Conseils
          </a>
        </li>
        <li role="none">
          <a
            href="/contact/"
            class={`nav-link px-4 py-2.5 text-sm font-medium rounded-full transition-all ${
              currentPath.startsWith('/contact')
                ? isHomePage
                  ? 'text-white bg-white/10 backdrop-blur-sm group-[.scrolled]:text-primary group-[.scrolled]:bg-primary/10'
                  : 'text-primary bg-primary/10'
                : isHomePage
                  ? 'text-white/90 hover:text-white hover:bg-white/10 group-[.scrolled]:text-gray-700 group-[.scrolled]:hover:text-primary group-[.scrolled]:hover:bg-gray-50'
                  : 'text-gray-700 hover:text-primary hover:bg-gray-50'
            }`}
            role="menuitem"
            aria-current={currentPath.startsWith('/contact') ? 'page' : undefined}
          >
            Contact
          </a>
        </li>
      </ul>

      <!-- Desktop CTA — visibilité gérée par CSS via .scrolled / .always-show -->
      <div id="desktop-cta" class="items-center gap-3">
        <a
          href={`tel:${siteConfig.phone}`}
          class={`inline-flex items-center space-x-2 px-4 py-2.5 rounded-full text-sm font-semibold shadow-sm transition-all ${
            isHomePage ? 'bg-primary text-dark hover:bg-primary-light' : 'bg-primary text-dark hover:bg-primary-light'
          }`}
          aria-label={`Appeler directement ${siteConfig.name}`}
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 5a2 2 0 012-2h2.28a1 1 0 01.95.684l1.22 3.663a1 1 0 01-.502 1.21l-1.52.76a11.042 11.042 0 005.516 5.516l.76-1.52a1 1 0 011.21-.502l3.663 1.22A1 1 0 0121 17.72V20a2 2 0 01-2 2h-1C9.716 22 3 15.284 3 7V5z"
            />
          </svg>
          <span>{siteConfig.phoneFormatted}</span>
        </a>
        <a
          href={`https://wa.me/${siteConfig.whatsapp}?text=${encodeURIComponent(
            'Bonjour, je souhaite un dépannage serrurier sur La Rochelle svp.',
          )}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center space-x-2 px-3 py-2 rounded-full text-xs font-medium border border-primary/60 text-primary hover:bg-primary/10 transition-all"
          aria-label="Contacter DSLR Serrurier La Rochelle sur WhatsApp"
        >
          <svg class="w-4 h-4" aria-hidden="true">
            <use href="#icon-whatsapp" />
          </svg>
          <span>WhatsApp</span>
        </a>
      </div>

      <!-- CTAs mobiles : toujours visibles dans la barre, à gauche du burger -->
      <div class="flex md:hidden items-center gap-1.5 ml-auto">
        <a
          href={`tel:${siteConfig.phone}`}
          class="flex items-center gap-1 pl-2 pr-2.5 py-1.5 rounded-full bg-primary text-dark text-[11px] font-semibold whitespace-nowrap leading-none"
          aria-label={`Appeler ${siteConfig.name}`}
        >
          <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h2.28a1 1 0 01.95.684l1.22 3.663a1 1 0 01-.502 1.21l-1.52.76a11.042 11.042 0 005.516 5.516l.76-1.52a1 1 0 011.21-.502l3.663 1.22A1 1 0 0121 17.72V20a2 2 0 01-2 2h-1C9.716 22 3 15.284 3 7V5z" />
          </svg>
          <span>{siteConfig.phoneFormatted}</span>
        </a>
        <a
          href={`https://wa.me/${siteConfig.whatsapp}?text=${encodeURIComponent('Bonjour, je souhaite un dépannage serrurier sur La Rochelle svp.')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center w-[2.1rem] h-[2.1rem] rounded-full border border-primary/70 text-primary"
          aria-label="Contacter sur WhatsApp"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12.04 2C6.587 2 2.24 6.347 2.24 11.8c0 2.08.61 4.02 1.77 5.73L2 22l4.62-1.95a9.7 9.7 0 005.42 1.6h.01c5.45 0 9.8-4.35 9.8-9.8C21.85 6.347 17.49 2 12.04 2zm0 17.4h-.01a7.57 7.57 0 01-3.86-1.06l-.28-.17-2.74 1.15.58-2.89-.19-.3a7.53 7.53 0 01-1.14-3.99c0-4.17 3.39-7.56 7.57-7.56 2.02 0 3.92.79 5.35 2.22a7.5 7.5 0 012.22 5.34c0 4.18-3.4 7.56-7.56 7.56zm4.15-5.64c-.23-.11-1.37-.68-1.58-.76-.21-.08-.36-.11-.52.11-.16.23-.6.76-.73.92-.13.15-.27.17-.5.06-.23-.11-.96-.35-1.82-1.12-.67-.6-1.12-1.35-1.25-1.58-.13-.23-.01-.35.1-.46.1-.1.23-.27.35-.4.12-.13.16-.23.23-.38.08-.15.04-.28-.02-.4-.06-.11-.52-1.26-.71-1.72-.19-.46-.38-.4-.52-.41h-.44c-.15 0-.4.06-.61.28-.21.23-.8.78-.8 1.9 0 1.12.82 2.2.94 2.36.11.15 1.6 2.44 3.9 3.42.55.24.98.39 1.31.5.55.17 1.05.15 1.45.09.44-.07 1.37-.56 1.56-1.1.19-.54.19-1 .13-1.1-.06-.1-.21-.16-.44-.27z"/>
          </svg>
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-button"
        class={`md:hidden rounded-lg transition-colors ${
          isHomePage ? 'text-white hover:bg-white/10 group-[.scrolled]:text-gray-700 group-[.scrolled]:hover:bg-gray-50' : 'text-gray-700 hover:text-primary hover:bg-gray-50'
        }`}
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu (fond blanc pour lisibilité) -->
    <div
      id="mobile-menu"
      class="hidden md:hidden mt-3 pb-4 pt-1 px-3 -mx-3 rounded-b-xl bg-white shadow-lg border-t border-gray-100"
      role="menu"
      aria-labelledby="mobile-menu-button"
    >
      <a
        href="/"
        class="block px-3 py-2.5 rounded-lg text-sm text-gray-800 hover:bg-gray-50 hover:text-primary transition-colors"
        role="menuitem"
        aria-current={currentPath === '/' ? 'page' : undefined}
      >
        Accueil
      </a>
      <a
        href="/prix/"
        class="block px-3 py-2.5 rounded-lg text-sm text-gray-800 hover:bg-gray-50 hover:text-primary transition-colors"
        role="menuitem"
        aria-current={currentPath.startsWith('/prix') ? 'page' : undefined}
      >
        Tarifs
      </a>
      <a
        href="/faq/"
        class="block px-3 py-2.5 rounded-lg text-sm text-gray-800 hover:bg-gray-50 hover:text-primary transition-colors"
        role="menuitem"
        aria-current={currentPath.startsWith('/faq') ? 'page' : undefined}
      >
        FAQ / Conseils
      </a>
      <a
        href="/contact/"
        class="block px-3 py-2.5 rounded-lg text-sm text-gray-800 hover:bg-gray-50 hover:text-primary transition-colors"
        role="menuitem"
        aria-current={currentPath.startsWith('/contact') ? 'page' : undefined}
      >
        Contact
      </a>
      <div class="mt-3 pt-3 border-t border-gray-100">
        <a
          href={`https://wa.me/${siteConfig.whatsapp}?text=${encodeURIComponent('Bonjour, je souhaite un dépannage serrurier sur La Rochelle svp.')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 px-3 py-2.5 rounded-full text-sm font-medium border border-emerald-500/60 text-emerald-600 hover:bg-emerald-50 transition-colors"
          role="menuitem"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12.04 2C6.587 2 2.24 6.347 2.24 11.8c0 2.08.61 4.02 1.77 5.73L2 22l4.62-1.95a9.7 9.7 0 005.42 1.6h.01c5.45 0 9.8-4.35 9.8-9.8C21.85 6.347 17.49 2 12.04 2zm0 17.4h-.01a7.57 7.57 0 01-3.86-1.06l-.28-.17-2.74 1.15.58-2.89-.19-.3a7.53 7.53 0 01-1.14-3.99c0-4.17 3.39-7.56 7.57-7.56 2.02 0 3.92.79 5.35 2.22a7.5 7.5 0 012.22 5.34c0 4.18-3.4 7.56-7.56 7.56zm4.15-5.64c-.23-.11-1.37-.68-1.58-.76-.21-.08-.36-.11-.52.11-.16.23-.6.76-.73.92-.13.15-.27.17-.5.06-.23-.11-.96-.35-1.82-1.12-.67-.6-1.12-1.35-1.25-1.58-.13-.23-.01-.35.1-.46.1-.1.23-.27.35-.4.12-.13.16-.23.23-.38.08-.15.04-.28-.02-.4-.06-.11-.52-1.26-.71-1.72-.19-.46-.38-.4-.52-.41h-.44c-.15 0-.4.06-.61.28-.21.23-.8.78-.8 1.9 0 1.12.82 2.2.94 2.36.11.15 1.6 2.44 3.9 3.42.55.24.98.39 1.31.5.55.17 1.05.15 1.45.09.44-.07 1.37-.56 1.56-1.1.19-.54.19-1 .13-1.1-.06-.1-.21-.16-.44-.27z"/>
          </svg>
          WhatsApp
        </a>
      </div>
    </div>
  </nav>

  <style>
    /* Desktop CTA : caché par défaut, affiché sur desktop uniquement via .scrolled ou .always-show */
    #desktop-cta { display: none; }
    @media (min-width: 768px) {
      #main-header.scrolled #desktop-cta,
      #main-header.always-show #desktop-cta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }
    }
  </style>

  <!-- Icône WhatsApp inline pour réutilisation -->
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="currentColor"
    class="hidden"
  >
    <symbol id="icon-whatsapp" viewBox="0 0 24 24">
      <path
        d="M12.04 2C6.587 2 2.24 6.347 2.24 11.8c0 2.08.61 4.02 1.77 5.73L2 22l4.62-1.95a9.7 9.7 0 005.42 1.6h.01c5.45 0 9.8-4.35 9.8-9.8C21.85 6.347 17.49 2 12.04 2zm0 17.4h-.01a7.57 7.57 0 01-3.86-1.06l-.28-.17-2.74 1.15.58-2.89-.19-.3a7.53 7.53 0 01-1.14-3.99c0-4.17 3.39-7.56 7.57-7.56 2.02 0 3.92.79 5.35 2.22a7.5 7.5 0 012.22 5.34c0 4.18-3.4 7.56-7.56 7.56zm4.15-5.64c-.23-.11-1.37-.68-1.58-.76-.21-.08-.36-.11-.52.11-.16.23-.6.76-.73.92-.13.15-.27.17-.5.06-.23-.11-.96-.35-1.82-1.12-.67-.6-1.12-1.35-1.25-1.58-.13-.23-.01-.35.1-.46.1-.1.23-.27.35-.4.12-.13.16-.23.23-.38.08-.15.04-.28-.02-.4-.06-.11-.52-1.26-.71-1.72-.19-.46-.38-.4-.52-.41h-.44c-.15 0-.4.06-.61.28-.21.23-.8.78-.8 1.9 0 1.12.82 2.2.94 2.36.11.15 1.6 2.44 3.9 3.42.55.24.98.39 1.31.5.55.17 1.05.15 1.45.09.44-.07 1.37-.56 1.56-1.1.19-.54.19-1 .13-1.1-.06-.1-.21-.16-.44-.27z"
      />
    </symbol>
  </svg>
</header>

<script>
  // ── Mobile menu toggle ──────────────────────────────────
  const menuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  if (menuButton && mobileMenu) {
    menuButton.addEventListener('click', () => {
      const expanded = menuButton.getAttribute('aria-expanded') === 'true';
      menuButton.setAttribute('aria-expanded', String(!expanded));
      mobileMenu.classList.toggle('hidden');
    });
  }

  // ── Comportement scroll sur la page d'accueil ──────────
  if (window.location.pathname === '/' || window.location.pathname === '/index.html') {
    const header = document.getElementById('main-header');
    const brandBlock = document.getElementById('brand-block');

    const handleScroll = () => {
      const hero = document.getElementById('hero');
      const headerHeight = header?.offsetHeight ?? 0;
      const heroBottom = hero ? hero.offsetTop + hero.offsetHeight : 0;
      const pastHero = hero
        ? window.pageYOffset + headerHeight >= heroBottom
        : window.pageYOffset > 80;

      if (pastHero) {
        header?.classList.add('scrolled', 'bg-white/95', 'backdrop-blur-sm', 'border-b', 'border-gray-200', 'shadow-sm');
        header?.classList.remove('bg-transparent', 'backdrop-blur-none');
        brandBlock?.classList.remove('opacity-0', 'pointer-events-none');
        brandBlock?.classList.add('opacity-100');
      } else {
        header?.classList.remove('scrolled', 'bg-white/95', 'backdrop-blur-sm', 'border-b', 'border-gray-200', 'shadow-sm');
        header?.classList.add('bg-transparent', 'backdrop-blur-none');
        brandBlock?.classList.add('opacity-0', 'pointer-events-none');
        brandBlock?.classList.remove('opacity-100');
      }
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();
  }
</script>

