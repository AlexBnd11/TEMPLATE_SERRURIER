---
import { testimonials } from '@config/testimonials';
import { siteConfig } from '@config/site';
---

<section id="avis-clients" class="scroll-mt-24 py-24 bg-white">
  <div class="container mx-auto px-4 lg:px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-semibold text-gray-900 mb-4">
          Avis clients sur DSLR Serrurier La Rochelle
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Des dizaines de clients dépannés chaque année sur La Rochelle et la CDA, avec des avis 5 étoiles sur Google.
        </p>
      </div>

      {testimonials.length > 0 && (
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-8 md:p-10 mb-10">
          <div
            class="flex items-center space-x-1 mb-4"
            aria-label={`Note moyenne de ${testimonials[0].rating} étoiles`}
          >
            {Array.from({ length: testimonials[0].rating }).map((_, i) => (
              <svg
                class="w-5 h-5 text-primary"
                fill="currentColor"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <blockquote class="text-xl md:text-2xl text-gray-900 font-light mb-4 leading-relaxed">
            "{testimonials[0].text}"
          </blockquote>
          <div class="flex items-center space-x-3">
            <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center text-primary font-semibold">
              {testimonials[0].name.charAt(0)}
            </div>
            <div>
              <div class="text-sm font-semibold text-gray-900">{testimonials[0].name}</div>
              <div class="text-xs text-gray-500">{testimonials[0].location}</div>
            </div>
          </div>
        </div>
      )}

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.slice(1).map((testimonial) => (
          <article class="bg-gray-50 border border-gray-200 rounded-xl p-6">
            <div
              class="flex items-center space-x-1 mb-3"
              aria-label={`Note de ${testimonial.rating} étoiles`}
            >
              {Array.from({ length: testimonial.rating }).map((_, i) => (
                <svg
                  class="w-4 h-4 text-primary"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                  aria-hidden="true"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-sm text-gray-700 mb-4 leading-relaxed">
              "{testimonial.text}"
            </p>
            <div class="flex items-center space-x-3">
              <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xs font-semibold">
                {testimonial.name.charAt(0)}
              </div>
              <div>
                <div class="text-sm font-semibold text-gray-900">{testimonial.name}</div>
                <div class="text-xs text-gray-500">{testimonial.location}</div>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="text-center mt-10">
        <a
          href={siteConfig.gmb?.url || '#'}
          class="inline-flex items-center justify-center px-5 py-3 rounded-full border border-gray-300 text-sm font-semibold text-gray-700 hover:border-primary hover:text-primary transition-colors disabled:opacity-60 disabled:hover:border-gray-300 disabled:hover:text-gray-700"
          aria-label="Voir les avis Google de DSLR Serrurier La Rochelle"
          {...(siteConfig.gmb?.url ? { target: '_blank', rel: 'noopener noreferrer' } : { 'aria-disabled': 'true' })}
        >
          Voir tous les avis sur Google
        </a>
      </div>
    </div>
  </div>
</section>

